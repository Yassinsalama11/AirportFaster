# =============================================================================
# AirportFaster — Environment Variables Reference
# Copy this to .env and fill in real values. Never commit .env to source control.
# =============================================================================

# ---- Database ----------------------------------------------------------------
DATABASE_URL="postgresql://yassin@localhost:5432/airportfaster_dev"

# ---- Redis -------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# ---- API Server --------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ---- Web / Next.js -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://airportfaster.com
NEXT_PUBLIC_SINAI_TAXI_URL=https://sinaitaxi.com
NEXT_PUBLIC_WHATSAPP_NUMBER=441748220006
WEB_PORT=3000

# ---- ISR Cache Invalidation --------------------------------------------------
# Shared secret between the API and Next.js revalidation endpoint.
REVALIDATE_SECRET="change-me-to-a-random-secret-string"

# ---- Auth / Session ----------------------------------------------------------
SESSION_SECRET="change-me-to-a-32-char-random-string"
# Session duration in seconds (default 8 hours)
SESSION_TTL_SECONDS=28800
PASSWORD_RESET_TTL_SECONDS=900
PASSWORD_RESET_SECRET="change-me-to-a-32-char-random-string"

# ---- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- AWS S3 / Storage --------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=airportfaster-public
AWS_S3_PUBLIC_BUCKET=airportfaster-public
AWS_S3_PRIVATE_BUCKET=airportfaster-private
AWS_CDN_BASE=https://cdn.airportfaster.com
AWS_CLOUDFRONT_URL=https://cdn.airportfaster.com
AWS_ENDPOINT_URL=

# ---- Airport Image Import ----------------------------------------------------
# Configure at least one provider before running scripts/import-airport-images.mjs.
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
AIRPORT_IMAGE_IMPORT_CONCURRENCY=15

# ---- Email -------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AirportFaster <no-reply@airportfaster.com>"
RESEND_API_KEY=
ZEPTOMAIL_API_KEY=
SALES_NOTIFICATION_EMAIL=sales@airportfaster.com

# ---- Sentry ------------------------------------------------------------------
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=airportfaster
SENTRY_PROJECT=airportfaster-web
SENTRY_AUTH_TOKEN=

# ---- PostHog -----------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ---- Seed / Admin ------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@airportfaster.local
SEED_ADMIN_PASSWORD=AirportFaster!Dev2026

# ---- Uptime Monitoring -------------------------------------------------------
# BETTERSTACK_API_KEY=
# BETTERSTACK_MONITOR_URL=
