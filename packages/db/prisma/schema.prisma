  id        String   @id @default(uuid()) @db.Uuid
  bookingId String?  @map("booking_id") @db.Uuid
  sessionId String?  @map("session_id")
  type      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([type, createdAt])
  @@index([bookingId])
  @@map("analytics_funnel_events")
}

model ConversionEvent {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String?  @map("session_id")
  type       String
  pageId     String?  @map("page_id") @db.Uuid
  valueMinor Int?     @map("value_minor")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([type, createdAt])
  @@map("conversion_events")
}

// =============================================================================
// Tax Domain
// =============================================================================

model TaxRate {
  id          String    @id @default(uuid()) @db.Uuid
  countryCode String    @map("country_code") @db.Char(2)
  taxType     String    @map("tax_type") // 'vat', 'gst', 'sales_tax'
  rate        Decimal   @db.Decimal(5, 4) // e.g. 0.2000 for 20% UK VAT
  serviceType String?   @map("service_type") // null = all services
  isActive    Boolean   @default(true) @map("is_active")
  validFrom   DateTime  @map("valid_from") @db.Date
  validUntil  DateTime? @map("valid_until") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([countryCode, isActive])
  @@map("tax_rates")
}

// =============================================================================
// Corporate Accounts Domain (T-073)
// =============================================================================

model CorporateAccount {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  legalName    String?  @map("legal_name")
  vatNumber    String?  @map("vat_number")
  billingEmail String   @map("billing_email")
  creditLimit  Int?     @map("credit_limit") // minor units
  paymentTerms Int      @default(30) @map("payment_terms") // days
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  members  CorporateMember[]
  bookings Booking[]         @relation("CorporateBookings")

  @@map("corporate_accounts")
}

model CorporateMember {
  id          String   @id @default(uuid()) @db.Uuid
  corporateId String   @map("corporate_id") @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  role        String   @default("member") // admin, member
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  corporate CorporateAccount @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  customer  Customer         @relation(fields: [customerId], references: [id])

  @@unique([corporateId, customerId])
  @@map("corporate_members")
}

// =============================================================================
// Public API / Developer Keys Domain (T-074)
// =============================================================================

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix") // e.g. "ap_live_Ab"
  supplierId String?   @map("supplier_id") @db.Uuid
  scopes     String[]  // ['search', 'bookings.read', 'bookings.write', 'pricing.read']
  rateLimit  Int       @default(1000) @map("rate_limit") // requests per hour
  status     String    @default("active")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("api_keys")
}
