generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Identity & Access Domain
// =============================================================================

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  sessions                  Session[]
  userRoles                 UserRole[]
  auditLogs                 AuditLog[]
  createdPages              Page[]                    @relation("PageCreatedBy")
  submittedContentWorkflows ContentApprovalWorkflow[] @relation("ContentWorkflowSubmittedBy")
  reviewedContentWorkflows  ContentApprovalWorkflow[] @relation("ContentWorkflowReviewedBy")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  displayName String   @map("display_name")
  description String?
  domain      String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastUsedAt DateTime @default(now()) @map("last_used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// Airports Domain
// =============================================================================

enum AirportStatus {
  draft
  active
  inactive
}

model Airport {
  id          String        @id @default(uuid()) @db.Uuid
  iataCode    String        @unique @map("iata_code")
  icaoCode    String?       @unique @map("icao_code")
  slug        String        @unique
  country     String        @db.Char(2) // ISO 3166-1 alpha-2
  city        String
  timezone    String
  latitude    Decimal?      @db.Decimal(10, 7)
  longitude   Decimal?      @db.Decimal(10, 7)
  status      AirportStatus @default(draft)
  publishedAt DateTime?     @map("published_at") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  translations        AirportTranslation[]
  images              AirportImage[]
  seo                 AirportSeo?
  airportServices     AirportService[]
  pages               Page[]
  supplierAirports    SupplierAirport[]
  supplierSchedules   SupplierScheduleLink[]

  @@index([country])
  @@index([status])
  @@map("airports")
}

model AirportTranslation {
  id          String   @id @default(uuid()) @db.Uuid
  airportId   String   @map("airport_id") @db.Uuid
  locale      String   @db.VarChar(10)
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)

  @@unique([airportId, locale])
  @@map("airport_translations")
}

model AirportImage {
  id        String   @id @default(uuid()) @db.Uuid
  airportId String   @map("airport_id") @db.Uuid
  url       String
  altText   String?  @map("alt_text")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)

  @@map("airport_images")
}

model AirportSeo {
  id              String   @id @default(uuid()) @db.Uuid
  airportId       String   @unique @map("airport_id") @db.Uuid
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  ogTitle         String?  @map("og_title")
  ogDescription   String?  @map("og_description")
  ogImage         String?  @map("og_image")
  canonicalUrl    String?  @map("canonical_url")
  schemaJson      Json?    @map("schema_json")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  airport   Airport                   @relation(fields: [airportId], references: [id], onDelete: Cascade)
  workflows ContentApprovalWorkflow[]

  @@map("airport_seo")
}

// =============================================================================
// Services Domain
// =============================================================================

enum ServiceStatus {
  draft
  active
  inactive
}

model Service {
  id        String        @id @default(uuid()) @db.Uuid
  slug      String        @unique
  icon      String?
  status    ServiceStatus @default(draft)
  sortOrder Int           @default(0) @map("sort_order")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  translations     ServiceTranslation[]
  seo              ServiceSeo?
  airportServices  AirportService[]
  pages            Page[]
  supplierServices SupplierService[]

  @@map("services")
}

model ServiceTranslation {
  id          String   @id @default(uuid()) @db.Uuid
  serviceId   String   @map("service_id") @db.Uuid
  locale      String   @db.VarChar(10)
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
  @@map("service_translations")
}

model ServiceSeo {
  id              String   @id @default(uuid()) @db.Uuid
  serviceId       String   @unique @map("service_id") @db.Uuid
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  ogTitle         String?  @map("og_title")
  ogDescription   String?  @map("og_description")
  canonicalUrl    String?  @map("canonical_url")
  schemaJson      Json?    @map("schema_json")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  service   Service                   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  workflows ContentApprovalWorkflow[]

  @@map("service_seo")
}

model AirportService {
  id               String   @id @default(uuid()) @db.Uuid
  airportId        String   @map("airport_id") @db.Uuid
  serviceId        String   @map("service_id") @db.Uuid
  isActive         Boolean  @default(true) @map("is_active")
  cutOffMinutes    Int?     @map("cut_off_minutes")
  minNoticeMinutes Int?     @map("min_notice_minutes")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  airport           Airport            @relation(fields: [airportId], references: [id], onDelete: Cascade)
  service           Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  pricingRules      PricingRule[]
  availabilityRules AvailabilityRule[]
  supplierCoverages SupplierCoverage[]
  bookings          Booking[]

  @@unique([airportId, serviceId])
  @@map("airport_services")
}

// =============================================================================
// Settings Domain
// =============================================================================

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json
  domain    String   @default("general")
  isPublic  Boolean  @default(false) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([domain])
  @@map("settings")
}

// =============================================================================
// CMS / SEO Domain
// =============================================================================

enum PageType {
  airport
  service
  airport_service
  guide
  faq
  policy
}

enum CmsPublishStatus {
  draft
  published
}

enum FaqScopeType {
  airport
  service
  airport_service
  page
  global
}

enum SchemaBlockStatus {
  draft
  published
}

enum SitemapLogStatus {
  success
  failed
}

enum SitemapLogTrigger {
  publish
  scheduled
  manual
}

enum ContentWorkflowEntityType {
  page_translation
  airport_seo
  service_seo
  faq
  translation_job
}

enum ContentWorkflowState {
  draft
  in_review
  approved
  published
  rejected
}

enum ContentWorkflowSource {
  human
  ai
}

model Page {
  id          String           @id @default(uuid()) @db.Uuid
  type        PageType
  slug        String           @unique
  status      CmsPublishStatus @default(draft)
  airportId   String?          @map("airport_id") @db.Uuid
  serviceId   String?          @map("service_id") @db.Uuid
  publishedAt DateTime?        @map("published_at") @db.Timestamptz
  createdById String?          @map("created_by") @db.Uuid
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  airport       Airport?          @relation(fields: [airportId], references: [id], onDelete: SetNull)
  service       Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdBy     User?             @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  translations  PageTranslation[]
  schemaBlocks  SchemaBlock[]
  outboundLinks InternalLink[]    @relation("InternalLinkFromPage")
  inboundLinks  InternalLink[]    @relation("InternalLinkToPage")

  @@index([type])
  @@index([status])
  @@index([airportId])
  @@index([serviceId])
  @@map("pages")
}

model PageTranslation {
  id              String   @id @default(uuid()) @db.Uuid
  pageId          String   @map("page_id") @db.Uuid
  locale          String   @db.VarChar(10)
  title           String
  h1              String?
  directAnswer    String?  @map("direct_answer")
  body            String?
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  aiSummary       String?  @map("ai_summary")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  page      Page                      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  workflows ContentApprovalWorkflow[]

  @@unique([pageId, locale])
  @@map("page_translations")
}

model Faq {
  id        String           @id @default(uuid()) @db.Uuid
  scopeType FaqScopeType     @map("scope_type")
  scopeId   String?          @map("scope_id") @db.Uuid
  locale    String           @db.VarChar(10)
  question  String
  answer    String
  sortOrder Int              @default(0) @map("sort_order")
  status    CmsPublishStatus @default(draft)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  workflows ContentApprovalWorkflow[]

  @@index([scopeType, scopeId])
  @@index([locale])
  @@index([status])
  @@map("faqs")
}

model SchemaBlock {
  id         String            @id @default(uuid()) @db.Uuid
  pageId     String            @map("page_id") @db.Uuid
  locale     String            @db.VarChar(10)
  schemaType String            @map("schema_type")
  schemaJson Json              @map("schema_json")
  status     SchemaBlockStatus @default(draft)
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, locale])
  @@index([schemaType])
  @@index([status])
  @@map("schema_blocks")
}

model InternalLink {
  id         String   @id @default(uuid()) @db.Uuid
  fromPageId String   @map("from_page_id") @db.Uuid
  toPageId   String   @map("to_page_id") @db.Uuid
  anchorText String   @map("anchor_text")
  locale     String   @db.VarChar(10)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  fromPage Page @relation("InternalLinkFromPage", fields: [fromPageId], references: [id], onDelete: Cascade)
  toPage   Page @relation("InternalLinkToPage", fields: [toPageId], references: [id], onDelete: Cascade)

  @@unique([fromPageId, toPageId, locale, anchorText])
  @@index([toPageId])
  @@map("internal_links")
}

model SitemapLog {
  id          String            @id @default(uuid()) @db.Uuid
  generatedAt DateTime          @default(now()) @map("generated_at") @db.Timestamptz
  urlCount    Int               @map("url_count")
  status      SitemapLogStatus
  trigger     SitemapLogTrigger
  error       String?
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz

  @@index([generatedAt])
  @@index([status])
  @@map("sitemap_logs")
}

model ContentApprovalWorkflow {
  id                String                    @id @default(uuid()) @db.Uuid
  entityType        ContentWorkflowEntityType @map("entity_type")
  entityId          String                    @map("entity_id") @db.Uuid
  state             ContentWorkflowState      @default(draft)
  source            ContentWorkflowSource     @default(human)
  submittedById     String?                   @map("submitted_by") @db.Uuid
  reviewedById      String?                   @map("reviewed_by") @db.Uuid
  reviewedAt        DateTime?                 @map("reviewed_at") @db.Timestamptz
  notes             String?
  pageTranslationId String?                   @map("page_translation_id") @db.Uuid
  airportSeoId      String?                   @map("airport_seo_id") @db.Uuid
  serviceSeoId      String?                   @map("service_seo_id") @db.Uuid
  faqId             String?                   @map("faq_id") @db.Uuid
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  submittedBy     User?            @relation("ContentWorkflowSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedBy      User?            @relation("ContentWorkflowReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  pageTranslation PageTranslation? @relation(fields: [pageTranslationId], references: [id], onDelete: Cascade)
  airportSeo      AirportSeo?      @relation(fields: [airportSeoId], references: [id], onDelete: Cascade)
  serviceSeo      ServiceSeo?      @relation(fields: [serviceSeoId], references: [id], onDelete: Cascade)
  faq             Faq?             @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([state])
  @@index([source])
  @@index([submittedById])
  @@index([reviewedById])
  @@map("content_approval_workflow")
}

// =============================================================================
// Pricing Domain
// =============================================================================

enum PricingMode {
  fixed
  cost_plus_markup
}

enum MarkupType {
  percentage
  fixed_amount
}

enum PricingRuleStatus {
  active
  inactive
}

enum DiscountType {
  percentage
  fixed
}

enum PromoStatus {
  active
  inactive
  expired
}

/// passengerPricing JSON shape: { "1": 1.0, "2": 0.95, "3": 0.90, ... }
/// keyed by passenger count string, value is a multiplier (1.0 = no change)
model PricingRule {
  id               String            @id @default(uuid()) @db.Uuid
  airportServiceId String            @map("airport_service_id") @db.Uuid
  supplierId       String?           @map("supplier_id") @db.Uuid
  mode             PricingMode
  basePriceMinor   Int?              @map("base_price_minor")
  supplierCostMinor Int?             @map("supplier_cost_minor")
  markupType       MarkupType?       @map("markup_type")
  markupValue      Decimal?          @db.Decimal(10, 4)
  currency         String            @db.VarChar(3)
  passengerPricing Json?             @map("passenger_pricing")
  peakRules        Json?             @map("peak_rules")
  validFrom        DateTime?         @map("valid_from") @db.Timestamptz
  validTo          DateTime?         @map("valid_to") @db.Timestamptz
  priority         Int               @default(0)
  status           PricingRuleStatus @default(active)
  createdById      String?           @map("created_by") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  airportService AirportService @relation(fields: [airportServiceId], references: [id], onDelete: Cascade)

  @@index([airportServiceId, status, priority])
  @@map("pricing_rules")
}

model CurrencyRate {
  id            String   @id @default(uuid()) @db.Uuid
  baseCurrency  String   @map("base_currency") @db.VarChar(3)
  quoteCurrency String   @map("quote_currency") @db.VarChar(3)
  rate          Decimal  @db.Decimal(18, 8)
  fetchedAt     DateTime @map("fetched_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([baseCurrency, quoteCurrency])
  @@map("currency_rates")
}

model PromoCode {
  id              String      @id @default(uuid()) @db.Uuid
  code            String      @unique @db.VarChar(50)
  discountType    DiscountType @map("discount_type")
  discountValue   Decimal     @db.Decimal(10, 4) @map("discount_value")
  currency        String?     @db.VarChar(3)
  maxRedemptions  Int?        @map("max_redemptions")
  redemptionsUsed Int         @default(0) @map("redemptions_used")
  validFrom       DateTime?   @map("valid_from") @db.Timestamptz
  validTo         DateTime?   @map("valid_to") @db.Timestamptz
  minBookingMinor Int?        @map("min_booking_minor")
  status          PromoStatus @default(active)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz

  @@map("promo_codes")
}

// =============================================================================
// Availability Domain
// =============================================================================

enum AvailabilityStatus {
  active
  inactive
}

enum BlackoutScopeType {
  airport
  airport_service
}

model AvailabilityRule {
  id               String             @id @default(uuid()) @db.Uuid
  airportServiceId String             @map("airport_service_id") @db.Uuid
  daysOfWeek       Int[]              @map("days_of_week")
  timeWindows      Json               @map("time_windows")
  cutOffMinutes    Int                @default(120) @map("cut_off_minutes")
  minNoticeMinutes Int                @default(60) @map("min_notice_minutes")
  capacityPerSlot  Int?               @map("capacity_per_slot")
  status           AvailabilityStatus @default(active)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  airportService AirportService @relation(fields: [airportServiceId], references: [id], onDelete: Cascade)

  @@index([airportServiceId, status])
  @@map("availability_rules")
}

model BlackoutDate {
  id        String            @id @default(uuid()) @db.Uuid
  scopeType BlackoutScopeType @map("scope_type")
  scopeId   String            @map("scope_id") @db.Uuid
  dateFrom  DateTime          @map("date_from") @db.Date
  dateTo    DateTime          @map("date_to") @db.Date
  reason    String?
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz

  @@index([scopeType, scopeId])
  @@map("blackout_dates")
}

model SupplierSchedule {
  id          String             @id @default(uuid()) @db.Uuid
  supplierId  String             @map("supplier_id") @db.Uuid
  airportId   String             @map("airport_id") @db.Uuid
  daysOfWeek  Int[]              @map("days_of_week")
  timeWindows Json               @map("time_windows")
  capacity    Int                @default(10)
  status      AvailabilityStatus @default(active)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  @@index([supplierId, airportId])
  @@map("supplier_schedules")
}

// =============================================================================
// Suppliers Domain
// =============================================================================

enum SupplierStatus {
  pending
  verified
  suspended
}

enum SupplierDocumentType {
  license
  contract
  insurance
  other
}

enum SupplierDocumentStatus {
  pending
  approved
  rejected
}

enum AssignmentMethod {
  manual
  rule_based
}

enum AssignmentStatus {
  offered
  accepted
  rejected
  reassigned
}

model Supplier {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  legalName       String?        @map("legal_name")
  status          SupplierStatus @default(pending)
  countryCode     String?        @map("country_code") @db.Char(2)
  rating          Decimal?       @db.Decimal(3, 2)
  reliabilityScore Decimal?      @map("reliability_score") @db.Decimal(3, 2)
  payoutCurrency  String?        @map("payout_currency") @db.VarChar(3)
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  contacts         SupplierContact[]
  supplierAirports SupplierAirport[]
  supplierServices SupplierService[]
  coverages        SupplierCoverage[]
  documents        SupplierDocument[]
  slaMetrics       SupplierSlaMetrics[]
  schedules        SupplierScheduleLink[]
  bookings         Booking[]
  assignments      BookingSupplierAssignment[]
  settlementLines  SettlementLine[]
  settlements      Settlement[]
  apiKeys          ApiKey[]

  @@index([status])
  @@map("suppliers")
}

model SupplierContact {
  id          String   @id @default(uuid()) @db.Uuid
  supplierId  String   @map("supplier_id") @db.Uuid
  name        String
  role        String?
  email       String?
  phone       String?
  whatsapp    String?
