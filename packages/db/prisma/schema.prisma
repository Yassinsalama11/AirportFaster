// =============================================================================
// Bookings Domain
// =============================================================================

enum BookingStatus {
  draft
  pending_payment
  paid
  pending_supplier_assignment
  supplier_assigned
  pending_supplier_confirmation
  confirmed
  in_progress
  completed
  cancelled
  refunded
  failed
}

enum BookingDirection {
  arrival
  departure
  transit
}

enum PassengerType {
  adult
  child
  infant
}

enum BookingSource {
  homepage
  airport_page
  service_page
  direct
  api
}

enum NoteVisibility {
  internal
  customer
}

enum ActorType {
  system
  staff
  supplier
  customer
}

model Customer {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  phone        String?
  whatsapp     String?
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  fullName     String?  @map("full_name")
  passwordHash String?  @map("password_hash")
  locale       String?  @db.VarChar(10)
  isVip        Boolean  @default(false) @map("is_vip")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  bookings         Booking[]
  corporateMembers CorporateMember[]

  @@index([email])
  @@map("customers")
}

model Booking {
  id                 String          @id @default(uuid()) @db.Uuid
  reference          String          @unique @db.VarChar(20)
  customerId         String          @map("customer_id") @db.Uuid
  airportServiceId   String          @map("airport_service_id") @db.Uuid
  supplierId         String?         @map("supplier_id") @db.Uuid
  corporateAccountId String?         @map("corporate_account_id") @db.Uuid
  status             BookingStatus   @default(draft)
  direction          BookingDirection
  serviceDateTime    DateTime        @map("service_datetime") @db.Timestamptz
  passengerCount     Int             @map("passenger_count")
  specialRequests    String?         @map("special_requests")
  locale             String?         @db.VarChar(10)
  currency           String          @db.VarChar(3)
  totalMinor         Int             @map("total_minor")
  manageTokenHash    String?         @map("manage_token_hash")
  manageTokenExpiresAt DateTime?     @map("manage_token_expires_at") @db.Timestamptz
  source             BookingSource   @default(homepage)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  customer         Customer                    @relation(fields: [customerId], references: [id])
  airportService   AirportService              @relation(fields: [airportServiceId], references: [id])
  supplier         Supplier?                   @relation(fields: [supplierId], references: [id])
  corporateAccount CorporateAccount?           @relation("CorporateBookings", fields: [corporateAccountId], references: [id])
  passengers       BookingPassenger[]
  flights          BookingFlight[]
  priceSnapshot    BookingPriceSnapshot?
  statusHistory    BookingStatusHistory[]
  assignments      BookingSupplierAssignment[]
  notes            BookingNote[]
  events           BookingEvent[]
  payments         Payment[]
  refunds          Refund[]

  @@index([status, serviceDateTime])
  @@index([customerId])
  @@index([airportServiceId])
  @@index([supplierId])
  @@index([corporateAccountId])
  @@map("bookings")
}

model BookingPassenger {
  id        String        @id @default(uuid()) @db.Uuid
  bookingId String        @map("booking_id") @db.Uuid
  fullName  String        @map("full_name")
  type      PassengerType @default(adult)
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_passengers")
}

model BookingFlight {
  id               String   @id @default(uuid()) @db.Uuid
  bookingId        String   @map("booking_id") @db.Uuid
  flightNumber     String   @map("flight_number") @db.VarChar(10)
  airlineCode      String?  @map("airline_code") @db.VarChar(3)
  scheduledTime    DateTime? @map("scheduled_time") @db.Timestamptz
  terminal         String?
  gate             String?
  flightStatus     String?  @map("flight_status") @db.VarChar(30)
  lastSyncedAt     DateTime? @map("last_synced_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_flights")
}

model BookingPriceSnapshot {
  id                      String   @id @default(uuid()) @db.Uuid
  bookingId               String   @unique @map("booking_id") @db.Uuid
  basePriceMinor          Int      @map("base_price_minor")
