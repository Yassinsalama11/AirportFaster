  promoCodeId             String?  @map("promo_code_id") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_price_snapshots")
}

model BookingStatusHistory {
  id         String     @id @default(uuid()) @db.Uuid
  bookingId  String     @map("booking_id") @db.Uuid
  fromStatus BookingStatus? @map("from_status")
  toStatus   BookingStatus  @map("to_status")
  actorType  ActorType  @map("actor_type") @default(system)
  actorId    String?    @map("actor_id") @db.Uuid
  reason     String?
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_status_history")
