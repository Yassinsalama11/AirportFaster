  bookingId      String           @map("booking_id") @db.Uuid
  supplierId     String           @map("supplier_id") @db.Uuid
  assignedBy     String?          @map("assigned_by") @db.Uuid
  assignmentMethod AssignmentMethod @map("assignment_method") @default(manual)
  status         AssignmentStatus @default(offered)
  offeredAt      DateTime         @default(now()) @map("offered_at") @db.Timestamptz
  respondedAt    DateTime?        @map("responded_at") @db.Timestamptz
  responseNote   String?          @map("response_note")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([bookingId])
  @@index([supplierId])
  @@map("booking_supplier_assignments")
}

model BookingNote {
  id           String         @id @default(uuid()) @db.Uuid
  bookingId    String         @map("booking_id") @db.Uuid
  authorUserId String?        @map("author_user_id") @db.Uuid
  body         String
  visibility   NoteVisibility @default(internal)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_notes")
}

model BookingEvent {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  type      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, type])
  @@map("booking_events")
}

// =============================================================================
// Payments & Settlements Domain
// =============================================================================

enum PaymentStatus {
  requires_payment
  processing
  succeeded
  failed
  refunded
  partially_refunded
}

enum PaymentMethodType {
  card
  bank_transfer
  wallet
}

enum TransactionType {
  charge
  refund
  adjustment
}

enum WebhookProcessingStatus {
  received
  processed
  failed
}

enum SettlementStatus {
  draft
  approved
  paid
}

enum PayoutStatus {
  pending
  processing
  paid
  failed
}

model Payment {
  id                   String            @id @default(uuid()) @db.Uuid
  bookingId            String            @map("booking_id") @db.Uuid
  stripePaymentIntentId String?          @unique @map("stripe_payment_intent_id")
  amountMinor          Int               @map("amount_minor")
  currency             String            @db.VarChar(3)
  status               PaymentStatus     @default(requires_payment)
  paymentMethodType    PaymentMethodType? @map("payment_method_type")
  capturedAt           DateTime?         @map("captured_at") @db.Timestamptz
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  booking      Booking              @relation(fields: [bookingId], references: [id])
  transactions PaymentTransaction[]
  refunds      Refund[]

  @@index([bookingId])
  @@index([status])
  @@map("payments")
}

model PaymentTransaction {
  id             String          @id @default(uuid()) @db.Uuid
  paymentId      String          @map("payment_id") @db.Uuid
  type           TransactionType
  amountMinor    Int             @map("amount_minor")
  currency       String          @db.VarChar(3)
  stripeObjectId String?         @map("stripe_object_id")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_transactions")
}

model StripeWebhookEvent {
  id               String                  @id @default(uuid()) @db.Uuid
  stripeEventId    String                  @unique @map("stripe_event_id")
  type             String
  payload          Json
  processingStatus WebhookProcessingStatus @default(received) @map("processing_status")
  processedAt      DateTime?               @map("processed_at") @db.Timestamptz
  error            String?
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz

  @@index([type])
  @@index([processingStatus])
  @@map("stripe_webhook_events")
}

model Settlement {
  id             String           @id @default(uuid()) @db.Uuid
  supplierId     String           @map("supplier_id") @db.Uuid
  periodStart    DateTime         @map("period_start") @db.Date
  periodEnd      DateTime         @map("period_end") @db.Date
  status         SettlementStatus @default(draft)
  grossMinor     Int              @map("gross_minor")
  deductionsMinor Int             @default(0) @map("deductions_minor")
  netPayableMinor Int             @map("net_payable_minor")
  currency       String           @db.VarChar(3)
  approvedBy     String?          @map("approved_by") @db.Uuid
  paidAt         DateTime?        @map("paid_at") @db.Timestamptz
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  supplier Supplier         @relation(fields: [supplierId], references: [id])
  lines    SettlementLine[]
  payouts  Payout[]

  @@index([supplierId, status])
  @@map("settlements")
}

model SettlementLine {
  id                   String   @id @default(uuid()) @db.Uuid
  settlementId         String   @map("settlement_id") @db.Uuid
  bookingId            String   @map("booking_id") @db.Uuid
  supplierId           String   @map("supplier_id") @db.Uuid
  supplierCostMinor    Int      @map("supplier_cost_minor")
  refundAdjustmentMinor Int     @default(0) @map("refund_adjustment_minor")
  penaltyMinor         Int      @default(0) @map("penalty_minor")
  netMinor             Int      @map("net_minor")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  supplier   Supplier   @relation(fields: [supplierId], references: [id])

  @@index([settlementId])
  @@index([bookingId])
  @@map("settlement_lines")
}

model Payout {
  id                String       @id @default(uuid()) @db.Uuid
  settlementId      String       @map("settlement_id") @db.Uuid
  amountMinor       Int          @map("amount_minor")
  currency          String       @db.VarChar(3)
  method            String?
  externalReference String?      @map("external_reference")
  status            PayoutStatus @default(pending)
  paidAt            DateTime?    @map("paid_at") @db.Timestamptz
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId, status])
  @@map("payouts")
}

// =============================================================================
// Refunds Domain
// =============================================================================

enum RefundType {
  full
  partial
  none
}

enum RefundStatus {
  requested
  admin_approved
  finance_approved
  processing
  completed
  rejected
}

enum RefundRequestedBy {
  customer
  staff
}

model CancellationPolicy {
  id                 String   @id @default(uuid()) @db.Uuid
  scopeType          String   @map("scope_type") @db.VarChar(30)
  scopeId            String?  @map("scope_id") @db.Uuid
  windows            Json
  supplierPenaltyRules Json?  @map("supplier_penalty_rules")
  status             AvailabilityStatus @default(active)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([scopeType, scopeId])
  @@map("cancellation_policies")
}

model Refund {
  id                  String             @id @default(uuid()) @db.Uuid
  bookingId           String             @map("booking_id") @db.Uuid
  paymentId           String?            @map("payment_id") @db.Uuid
  type                RefundType         @default(partial)
  requestedAmountMinor Int               @map("requested_amount_minor")
  approvedAmountMinor  Int?              @map("approved_amount_minor")
  currency            String             @db.VarChar(3)
  reason              String?
  requestedBy         RefundRequestedBy  @map("requested_by") @default(customer)
  policySnapshot      Json?              @map("policy_snapshot")
  status              RefundStatus       @default(requested)
  adminApprovedBy     String?            @map("admin_approved_by") @db.Uuid
  financeApprovedBy   String?            @map("finance_approved_by") @db.Uuid
  stripeRefundId      String?            @map("stripe_refund_id")
  completedAt         DateTime?          @map("completed_at") @db.Timestamptz
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  booking       Booking               @relation(fields: [bookingId], references: [id])
  payment       Payment?              @relation(fields: [paymentId], references: [id])
  statusHistory RefundStatusHistory[]

  @@index([bookingId])
  @@index([status])
  @@map("refunds")
}

model RefundStatusHistory {
  id         String       @id @default(uuid()) @db.Uuid
  refundId   String       @map("refund_id") @db.Uuid
  fromStatus RefundStatus? @map("from_status")
  toStatus   RefundStatus  @map("to_status")
  actorId    String?      @map("actor_id") @db.Uuid
  note       String?
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz

  refund Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId])
  @@map("refund_status_history")
}

// =============================================================================
// Incidents Domain
// =============================================================================

enum IncidentType {
  flight_delay
  supplier_no_show
  passenger_no_show
  wrong_terminal
  communication_failure
  payment_issue
  service_complaint
  other
}

enum IncidentSeverity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  created
  assigned
  in_progress
  waiting_external
  resolved
  closed
}

enum IncidentTeam {
  operations
  support
  finance
  supplier_manager
}

model Incident {
  id             String           @id @default(uuid()) @db.Uuid
  bookingId      String?          @map("booking_id") @db.Uuid
  supplierId     String?          @map("supplier_id") @db.Uuid
  type           IncidentType
  severity       IncidentSeverity @default(medium)
  status         IncidentStatus   @default(created)
  openedBy       String?          @map("opened_by") @db.Uuid
  resolutionReason String?        @map("resolution_reason")
  resolvedAt     DateTime?        @map("resolved_at") @db.Timestamptz
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  updates     IncidentUpdate[]
  assignments IncidentAssignment[]

  @@index([status, severity])
  @@index([bookingId])
  @@map("incidents")
}

model IncidentUpdate {
  id           String   @id @default(uuid()) @db.Uuid
  incidentId   String   @map("incident_id") @db.Uuid
  authorUserId String?  @map("author_user_id") @db.Uuid
  body         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_updates")
}

model IncidentAssignment {
  id             String       @id @default(uuid()) @db.Uuid
  incidentId     String       @map("incident_id") @db.Uuid
  assignedToUserId String?    @map("assigned_to_user_id") @db.Uuid
  assignedTeam   IncidentTeam? @map("assigned_team")
  assignedAt     DateTime     @default(now()) @map("assigned_at") @db.Timestamptz

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_assignments")
}

