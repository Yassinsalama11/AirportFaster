{
  "name": "@airportfaster/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint for db package'",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "DATABASE_URL=$(grep DATABASE_URL ../../.env | cut -d= -f2- | tr -d '\"') prisma migrate dev",
    "db:migrate:prod": "DATABASE_URL=$(grep DATABASE_URL ../../.env | cut -d= -f2- | tr -d '\"') prisma migrate deploy",
    "db:seed": "npx tsx --env-file=../../.env prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.0",
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
