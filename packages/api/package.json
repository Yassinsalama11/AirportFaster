{
  "name": "@airportfaster/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test node --env-file-if-exists=../../.env --experimental-test-module-mocks --import tsx --test \"src/**/*.test.ts\"",
    "test:e2e": "NODE_ENV=test node --env-file-if-exists=../../.env --experimental-test-module-mocks --import tsx --test \"src/__tests__/e2e/**/*.test.ts\"",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@airportfaster/db": "workspace:*",
    "@airportfaster/shared": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@node-rs/argon2": "^2.0.0",
    "@sentry/node": "^8.0.0",
    "@types/nodemailer": "^8.0.0",
    "bullmq": "^5.76.8",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.10.1",
    "nanoid": "^5.0.0",
    "nodemailer": "^8.0.7",
    "openai": "^6.37.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "stripe": "^22.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
