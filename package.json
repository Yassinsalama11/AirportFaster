{
  "name": "airportfaster",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build --filter=!@airportfaster/mobile",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint --filter=!@airportfaster/mobile",
    "typecheck": "turbo run typecheck --filter=!@airportfaster/mobile",
    "test": "turbo run test --filter=!@airportfaster/mobile",
    "sync:gm-travel": "node scripts/import-gm-travel-solution-prices.mjs",
    "sync:gm-travel:dry-run": "node scripts/import-gm-travel-solution-prices.mjs --dry-run",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "@swc/core",
      "core-js",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "protobufjs",
      "sharp"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
